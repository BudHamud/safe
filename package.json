{
  "name": "gastos-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "patch-package && prisma generate",
    "cap:dev": "cp capacitor.config.dev.ts capacitor.config.ts && npx cap sync android",
    "cap:prod": "cp capacitor.config.prod.ts capacitor.config.ts && npx cap sync android",
    "apk:dev": "cp capacitor.config.dev.ts capacitor.config.ts && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "apk:prod": "cp capacitor.config.prod.ts capacitor.config.ts && npx cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@posx/capacitor-notifications-listener": "^5.0.7",
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "port-kill": "^1.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "patch-package": "^8.0.1",
    "prisma": "5.22.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@posx/capacitor-notifications-listener": {
      "@capacitor/core": "$@capacitor/core"
    }
  }
}
