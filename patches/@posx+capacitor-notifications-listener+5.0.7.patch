+    /**
+     * Simulates the manual "disable then re-enable" toggle in Notification Access settings.
+     *
+     * requestRebind() alone is ignored by MIUI/HyperOS when the service was killed
+     * (not cleanly unbound). Calling requestUnbind() first marks the binding as
+     * voluntarily released, so the subsequent requestRebind() is always honored.
+     *
+     * The 600ms delay between unbind and rebind gives the system enough time to
+     * process the disconnect before we ask it to reconnect.
+     */
+    private void triggerRebindCycle(String caller) {
+        if (Build.VERSION.SDK_INT < Build.VERSION_CODES.N) return;
+
+        // Step 1: if the service instance is alive, request voluntary unbind
+        if (NotificationService.instance != null) {
+            try {
+                NotificationService.instance.requestUnbind();
+                Log.d(TAG, caller + " triggerRebindCycle: requestUnbind dispatched");
+            } catch (Exception e) {
+                Log.e(TAG, caller + " triggerRebindCycle: requestUnbind failed: " + e.getMessage());
+            }
+        }
+
+        // Step 2: after the system processes the disconnect, request fresh rebind
+        new Handler(Looper.getMainLooper()).postDelayed(() -> {
+            try {
+                ComponentName cn = new ComponentName(getContext(), NotificationService.class);
+                android.service.notification.NotificationListenerService.requestRebind(cn);
+                Log.d(TAG, caller + " triggerRebindCycle: requestRebind dispatched");
+            } catch (Exception e) {
+                Log.e(TAG, caller + " triggerRebindCycle: requestRebind failed: " + e.getMessage());
+            }
+        }, 600);
+    }
